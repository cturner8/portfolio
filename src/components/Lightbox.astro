---
import { Image } from "astro:assets";
import type { ComponentProps } from "astro/types";

type Props = ComponentProps<typeof Image>;

const props = Astro.props;
const id = `lb-${crypto.randomUUID()}`;
---

<input
  type="checkbox"
  id={id}
  class="lightbox-toggle"
  aria-hidden="true"
  tabindex="-1"
/>

<label for={id} class="lightbox-trigger" aria-label={`Enlarge image: ${props.alt}`}>
  <Image {...props} />
</label>

<div class="lightbox" role="dialog" aria-label={`Enlarged image: ${props.alt}`}>
  <label for={id} class="lightbox-backdrop" aria-label="Close enlarged image"></label>
  <Image {...props} class="lightbox-img" />
  <label for={id} class="lightbox-close" aria-label="Close enlarged image">
    <span aria-hidden="true">&times;</span>
  </label>
</div>

<style>
  .lightbox-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    margin: 0;
  }

  .lightbox-trigger {
    display: block;
    width: 100%;
    cursor: zoom-in;
    border-radius: 6px;
  }

  .lightbox-trigger :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    border: 1px solid var(--moretranswhite);
    transition: outline 0.15s ease;
  }

  .lightbox-trigger:hover :global(img),
  .lightbox-toggle:focus-visible + .lightbox-trigger :global(img) {
    outline: 2px solid var(--gray);
    outline-offset: 2px;
  }

  .lightbox {
    display: none;
  }

  .lightbox-toggle:checked ~ .lightbox {
    display: grid;
    place-items: center;
    position: fixed;
    inset: 0;
    z-index: 1000;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.9);
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    cursor: zoom-out;
  }

  .lightbox :global(img.lightbox-img) {
    position: relative;
    display: block;
    max-width: min(95vw, 100%);
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border: none;
    border-radius: 0;
    cursor: default;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.75rem;
    line-height: 2.25rem;
    text-align: center;
    background: var(--darkblue);
    color: var(--white);
    border: 1px solid var(--moretranswhite);
    border-radius: 50%;
    cursor: pointer;
  }

  .lightbox-close:hover,
  .lightbox-toggle:focus-visible ~ .lightbox .lightbox-close {
    outline: 2px solid var(--gray);
    outline-offset: 2px;
  }
</style>
