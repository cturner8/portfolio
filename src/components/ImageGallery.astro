---
interface Props {
  columns?: number;
}

const { columns = 2 } = Astro.props;
---

<div class="gallery" style={`--columns: ${columns}`}>
  <slot />
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: 0.75rem;
    margin: 0.5rem 0;
  }

  .gallery :global(img) {
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--moretranswhite);
    cursor: pointer;
    transition: outline 0.15s ease;
  }

  .gallery :global(img:hover) {
    outline: 2px solid var(--gray);
    outline-offset: 2px;
  }

  .gallery :global(p) {
    margin: 0;
  }

  @media (max-width: 600px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
