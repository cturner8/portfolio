---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import ColorScript from "../components/ColorScript.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HomePosts from "../components/HomePosts.astro";
import Tags from "../components/Tags.astro";
import { getTags } from "../scripts/getTags";
import { subtitle, title } from "../settings/settings.json";
import { Content as About } from "./about.md";

const posts = await getCollection("posts");
const tags = getTags(posts);
---

<!doctype html>
<html lang="en-us">
  <BaseHead title={title} description={subtitle} />
  <body>
    <Header title={title} />
    <main>
      <About />

      <br />

      <h3>Here's my most recent posts</h3>

      <HomePosts allPosts={posts} />

      <p class="center">
        You can also <a href="https://cturner8.dev/rss.xml">
          subscribe with RSS!
        </a>
      </p>
      <br />

      <Tags tags={tags} all />
    </main>
    <Footer />
    <ColorScript />
  </body>
</html>
